<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Neha I Am Very Sorry</title>

    <style>
        body {
            margin: 0;
            padding: 0;
            background: linear-gradient(to bottom, #1a1a1a, #000000);
            color: white;
            font-family: Arial, sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            text-align: center;
        }

        .container {
            max-width: 600px;
        }

        h1 {
            font-size: 2.5rem;
            margin-bottom: 40px;
            color: #dcdcdc;
        }

        button {
            padding: 15px 30px;
            font-size: 18px;
            border: none;
            border-radius: 10px;
            background-color: #444;
            color: white;
            cursor: pointer;
            transition: 0.3s;
        }

        button:hover {
            background-color: #666;
        }

        #message {
            margin-top: 30px;
            font-size: 24px;
            display: none;
            color: #ffb3b3;
        }
    </style>
</head>
<body>

    <div class="container">
        <h1>Neha I Am Very Sorry</h1>

        <button onclick="showMessage()">
            Click Here
        </button>

        <div id="message">
            Sorry Neha, please gimme follow back.
        </div>
    </div>

    <script>
        function showMessage() {
            document.getElementById("message").style.display = "block";
        }
    </script>

</body>
</html>
